# ══════════════════════════════════════════════════════════════════════
#   Face OSINT — .env.example
#   Copy to .env and fill in keys you want to use.
#   The system works WITHOUT any keys — free sources run automatically.
#   Keys unlock additional sources with higher result counts.
# ══════════════════════════════════════════════════════════════════════

# ── System ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO      # DEBUG | INFO | WARNING | ERROR

# ── Search Engines (improves URL discovery quality) ───────────────────

# Google Custom Search — 100 free queries/day
# Setup: https://programmablesearchengine.google.com
# Then:  https://console.developers.google.com → Custom Search API key
GOOGLE_CSE_KEY=
GOOGLE_CSE_ID=

# Bing Web Search — 1,000 free queries/month
# Setup: https://portal.azure.com → Cognitive Services → Bing Search v7
BING_API_KEY=

# Brave Search — 2,000 free queries/month
# Setup: https://api.search.brave.com
BRAVE_API_KEY=

# ── Platform APIs (all have meaningful free tiers) ────────────────────

# GitHub — 5,000 req/hour with token, 60/hour without
# Setup: https://github.com/settings/tokens → Generate new token (classic)
#        No scopes needed — public data only
GITHUB_TOKEN=

# GitLab — required since 2024 for user search (free personal token works)
# Setup: https://gitlab.com/-/profile/personal_access_tokens → read_user scope
GITLAB_TOKEN=

# Reddit — optional, falls back to public JSON search without keys
# Setup: https://www.reddit.com/prefs/apps → Create app (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=FaceOSINT/1.0

# ── Reverse face search (unlocks the most powerful engine) ────────────

# SerpApi — Google Lens + Yandex via API (100 free searches/month)
# Setup: https://serpapi.com/users/sign_up
SERPAPI_KEY=

# imgbb — image hosting for SerpApi and Yandex uploads (free)
# Setup: https://imgbb.com → Account → API
IMGBB_API_KEY=

# ── Email intelligence (optional) ─────────────────────────────────────

# Hunter.io — 25 free searches/month
# Setup: https://hunter.io/api-keys
HUNTER_API_KEY=

# ── Reverse face search (optional) ────────────────────────────────────

# FaceCheck.id reverse face search (beta API — leave blank if not available)
FACECHECK_API_KEY=

# PimEyes reverse face search (paid, https://pimeyes.com)
PIMEYES_API_KEY=

# ── Academic / research (optional) ────────────────────────────────────

# OpenAlex — optional but recommended; providing your email places you in the
# "polite pool" which has significantly higher rate limits (no registration needed)
# See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=your@email.com

# ══════════════════════════════════════════════════════════════════════
#   NOTES:
#   • Academic sources (Semantic Scholar, OpenAlex, ORCID) need NO key
#   • Passive sources (Wayback Machine, GDELT, crt.sh) need NO key
#   • Reverse image search (Yandex, Bing Visual) needs NO key
#   • Without any keys the system still uses ~8 free sources
# ══════════════════════════════════════════════════════════════════════
